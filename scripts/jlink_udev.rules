# Install to /etc/udev/rules.d/99-jlink.rules
#
# Some Linux distributions expose J-Link devices under SUBSYSTEM=="usb",
# while older SEGGER rules only match SUBSYSTEM=="usb_device".
# Matching both keeps the permission rule effective across systems.
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="1366", MODE="0666", ENV{ID_MM_DEVICE_IGNORE}="1"
ACTION=="add", SUBSYSTEM=="usb_device", ATTR{idVendor}=="1366", MODE="0666", ENV{ID_MM_DEVICE_IGNORE}="1"
